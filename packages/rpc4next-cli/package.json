{
  "name": "rpc4next-cli",
  "version": "0.7.0",
  "description": "Command line interface for rpc4next. Generates RPC client type definitions from Next.js routes.",
  "homepage": "https://github.com/watanabe-1/rpc4next#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/watanabe-1/rpc4next.git",
    "directory": "packages/rpc4next-cli"
  },
  "license": "MIT",
  "author": "watanabe-1",
  "type": "module",
  "engines": {
    "node": ">=20.19.2"
  },
  "bin": {
    "rpc4next": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run clean && bun build.ts",
    "clean": "bun -e \"const fs=require('fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('tsconfig.tsbuildinfo',{force:true});\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage.enabled true",
    "test:ui": "vitest --ui --coverage.enabled true",
    "test:watch": "vitest --watch",
    "lint": "biome check src",
    "check:fix": "biome check --write src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "rpc4next-shared": "workspace:*"
  },
  "peerDependencies": {
    "next": "^15.0.0 || ^16.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
