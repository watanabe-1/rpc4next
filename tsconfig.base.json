{
  "compilerOptions": {
    "target": "ES2022",
    "outDir": "${configDir}/dist",
    "rootDir": "${configDir}/src",
    "composite": true,
    "resolveJsonModule": true,
    "declaration": true,
    "emitDeclarationOnly": false,
    "sourceMap": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noErrorTruncation": true
  }
}
