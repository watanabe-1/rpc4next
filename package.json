{
  "name": "rpc4next-monorepo",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/watanabe-1/rpc4next.git"
  },
  "workspaces": [
    "packages/*",
    "integration/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun --filter \"./packages/*\" --if-present build",
    "clean": "bun --filter \"./packages/*\" --if-present clean",
    "typecheck": "bun run --parallel typecheck:scripts typecheck:workspaces",
    "typecheck:scripts": "tsc -p scripts/tsconfig.json",
    "typecheck:workspaces": "bun run --parallel --filter \"./packages/*\" --filter \"./integration/*\" --if-present typecheck",
    "lint": "bun run format:oxfmt:check && oxlint .",
    "lint:oxlint": "oxlint .",
    "check:fix": "oxfmt . && oxlint --fix .",
    "format:oxfmt": "oxfmt .",
    "format:oxfmt:check": "oxfmt --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage.enabled true",
    "test:ui": "vitest --ui --coverage.enabled true",
    "test:watch": "vitest --watch",
    "integration:next-app:generate": "bun run --cwd integration/next-app generate:rpc",
    "integration:next-app:watch": "bun run --cwd integration/next-app generate:rpc:watch",
    "integration:next-app:e2e": "bun run --cwd integration/next-app e2e",
    "integration:next-app:dev": "bun run --cwd integration/next-app dev",
    "diff2prompt": "diff2prompt --excludeFile=.gitignore"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "arktype": "^2.2.0",
    "diff2prompt": "^0.0.10",
    "esbuild": "^0.28.0",
    "fast-glob": "^3.3.3",
    "msw": "^2.13.4",
    "next": "16.2.4",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^6.0.3",
    "valibot": "^1.3.1",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=20.19.2"
  }
}
