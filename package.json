{
  "name": "rpc4next-monorepo",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/watanabe-1/rpc4next.git"
  },
  "workspaces": [
    "packages/*",
    "integration/*"
  ],
  "engines": {
    "node": ">=20.19.2"
  },
  "scripts": {
    "build": "bun --filter \"./packages/*\" --if-present build",
    "clean": "bun --filter \"./packages/*\" --if-present clean",
    "typecheck": "bun --filter \"./packages/*\" --if-present typecheck && bun --filter \"./integration/*\" --if-present typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:biome:demo": "biome check --config-path biome/biome.demo.json biome/tests",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage.enabled true",
    "test:ui": "vitest --ui --coverage.enabled true",
    "test:watch": "vitest --watch",
    "integration:next-app:generate": "bun run --cwd integration/next-app generate:rpc",
    "integration:next-app:watch": "bun run --cwd integration/next-app generate:rpc:watch",
    "integration:next-app:e2e": "bun run --cwd integration/next-app e2e",
    "integration:next-app:dev": "bun run --cwd integration/next-app dev",
    "diff2prompt": "diff2prompt --excludeFile=.gitignore"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "diff2prompt": "^0.0.9",
    "esbuild": "^0.27.3",
    "fast-glob": "^3.3.3",
    "msw": "^2.12.10",
    "next": "16.1.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  }
}
