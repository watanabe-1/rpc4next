{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "integration/**/app/**/route-contract.ts",
    "integration/**/src/generated/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/bin/**",
    "**/.next/**",
    "**/coverage/**",
    "**/playwright-report/**",
    "**/test-results/**"
  ],
  "jsPlugins": ["./oxlint/rpc4next.mjs"],
  "options": {
    "reportUnusedDisableDirectives": "error"
  },
  "rules": {
    "rpc4next/comment-spacing": "error",
    "rpc4next/padding-line-before-return": "error",
    "eqeqeq": "error",
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "caughtErrorsIgnorePattern": "^_",
        "destructuredArrayIgnorePattern": "^_"
      }
    ]
  },
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.test.tsx", "**/*.test.mts", "**/*.test.cts"],
      "plugins": ["vitest"],
      "env": {
        "vitest": true
      },
      "rules": {
        "vitest/consistent-test-it": ["error", { "fn": "it" }],
        "vitest/require-top-level-describe": "error",
        "vitest/no-focused-tests": "error",
        "vitest/no-disabled-tests": "error",
        "vitest/no-duplicate-hooks": "error",
        "vitest/no-standalone-expect": "error",
        "vitest/expect-expect": "error",
        "vitest/no-conditional-expect": "error",
        "rpc4next/no-export": "error"
      }
    }
  ]
}
