{
  "name": "@integration/next-app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --bun next dev",
    "dev:e2e": "bun --bun next dev --port 3100",
    "build": "bun run generate:rpc && bun --bun next build",
    "start": "bun --bun next start",
    "test": "bun run generate:rpc && tsc --noEmit && vitest run --config ../../vitest.config.ts src/*.test.ts",
    "e2e": "bun run generate:rpc && playwright test",
    "typecheck": "bun run generate:rpc && tsc --noEmit",
    "generate:rpc": "bun --bun ../../packages/rpc4next-cli/src/cli/index.ts",
    "generate:rpc:watch": "bun --bun ../../packages/rpc4next-cli/src/cli/index.ts --watch",
    "generate:rpc:dist": "rpc4next",
    "generate:rpc:dist:watch": "rpc4next --watch"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rpc4next": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "rpc4next-cli": "workspace:*"
  }
}
